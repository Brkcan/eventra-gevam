APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=eventra
POSTGRES_URL=postgresql://eventra:eventra@postgres:5432/eventra
REDIS_URL=redis://redis:6379
PORT=3001
CACHE_LOADER_PORT=3010
CACHE_LOADER_METADATA_DB_URL=postgresql://eventra:eventra@postgres:5432/eventra
KAFKAJS_NO_PARTITIONER_WARNING=1
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Eventra <your_email@gmail.com>"
EMAIL_DRY_RUN=false
