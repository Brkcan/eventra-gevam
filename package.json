{
  "name": "eventra",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "docker:infra:up": "docker compose -f infra/docker/docker-compose.local.yml up -d",
    "docker:infra:down": "docker compose -f infra/docker/docker-compose.local.yml down",
    "docker:infra:logs": "docker compose -f infra/docker/docker-compose.local.yml logs -f",
    "docker:infra:ps": "docker compose -f infra/docker/docker-compose.local.yml ps",
    "dev:api": "npm --workspace @eventra/api run dev",
    "dev:rule-engine": "npm --workspace @eventra/rule-engine run dev",
    "dev:listener-hub": "npm --workspace @eventra/listener-hub run dev",
    "dev:kafka-ui": "npm --workspace @eventra/kafka-ui run dev",
    "dev:frontend": "npm --workspace @eventra/frontend run dev",
    "start:api": "npm --workspace @eventra/api run start",
    "start:rule-engine": "npm --workspace @eventra/rule-engine run start",
    "start:listener-hub": "npm --workspace @eventra/listener-hub run start",
    "smoke:listener-hub": "npm --workspace @eventra/listener-hub run smoke",
    "build:kafka-ui": "npm --workspace @eventra/kafka-ui run build",
    "dev:cache-loader": "npm --workspace @eventra/cache-loader run dev",
    "start:cache-loader": "npm --workspace @eventra/cache-loader run start",
    "build:frontend": "npm --workspace @eventra/frontend run build"
  }
}
